# Стили текста
style dream_style:
    font "fonts/dream.ttf"
    size 32
    color "#8f12c5"

style horror_style:
    font "fonts/dream.ttf"
    size 32
    color "#e32416"

style check_style:
    font "fonts/check.ttf"
    size 32
    color "#1ae9db"

# Настраиваем внешний вид текста (размер, цвет, шрифт)
style death_style:
    font "fonts/dream.ttf"
    xalign 0.5
    size 60
    color "#ffffff"
    outlines [ (2, "#000000", 0, 0) ]