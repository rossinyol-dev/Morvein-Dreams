    # narrator "Надо поскорее добраться до особняка Триллианов..."
    narrator "You need to reach the Trillian manor as quickly as possible..."

# game/src/scenario/act1.rpy:949
translate english act_1_rykard_gang_counter_08b847d1:

    # narrator "Главарь преграждает тебе путь и окидывает взглядом с головы до ног."
