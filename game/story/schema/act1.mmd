flowchart TD

    A["Начало Акта I<br>Массовый исход лунатиков"]

    A --> B{"Расследование"}

    B --> C["Собственное расследование"]
    B --> D["Архивы Ордена"]

    C --> E["Изменение ord_rel / cult_rel"]
    D --> E

    E --> F["Появление дворянина"]
    F --> G["Приглашение на встречу"]

    G --> H{"ord_rel очень высокий?"}

    H -->|Да| I["Сообщить Стефану"]
    H -->|Нет| J["Посетить встречу"]

    I --> K["Рейд Ордена"]
    K --> L["Арест участников"]
    L --> M["Допрос"]

    M --> N{"cult_rel > 0?"}

    N -->|Да| O["Отречение от Ордена"]
    N -->|Нет| P["Остаться с Орденом"]

    P --> Q["Экспедиция Ордена"]

    J --> R{"cult_rel высокий?"}

    R -->|Да| S["Принятие культистами"]

    R -->|Нет| T["Квест доверия"]

    T --> U{"Квест выполнен?"}

    U -->|Да| S
    U -->|Нет| V["Провал доверия"]

    O --> W["Герой идет один"]
    V --> W

    S --> X["Проводник культистов"]

    Q --> Y["Древний храм под Морвейном"]
    X --> Y
    W --> Y

    Y --> Z["Конец Акта I"]

    class A,Z act
    class C,E,F,G neutral
    class B,H,N,R,U condition
    class D,I,K,L,M,P,Q order
    class J,S,T,X cult
    class O,V,W solo
    class Y temple

    classDef act fill:#ffcc99,stroke:#cc6600,stroke-width:4px,color:#000
    classDef neutral fill:#fff2b2,stroke:#b38f00,stroke-width:2px,color:#000
    classDef condition fill:#ffcccc,stroke:#cc0000,stroke-width:3px,color:#000
    classDef order fill:#cfe2ff,stroke:#3366cc,stroke-width:3px,color:#000
    classDef cult fill:#d9f2d9,stroke:#339966,stroke-width:3px,color:#000
    classDef solo fill:#d9d9d9,stroke:#666666,stroke-width:3px,color:#000
    classDef temple fill:#e6d5ff,stroke:#7a4dbb,stroke-width:4px,color:#000

    linkStyle default stroke-width:4px