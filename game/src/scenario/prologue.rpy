# Пролог
label prologue:
    $ hard_fade(scene_name="morvein_start", show_gui=False)

    narrator "Дождь шел уже шестой день подряд. Морвейн всегда пах одинаково: мокрым камнем, свечным воском и затхлой водой из старых каналов."
    narrator "Горожане давно перестали замечать этот запах. Как и многое другое."
    narrator "Ночные колокола. Людей, засыпающих прямо посреди разговора. Детей, которые по утрам рассказывают о местах, где никогда не были."
    narrator "В Морвейне привыкли не задавать лишних вопросов. Особенно ночью."
    narrator "Но ты оказался здесь не случайно. У каждого, кто приезжает в Морвейн, есть своя причина. Своя история."
    narrator "И свои сны."

    call screen char_choice()
    $ result = _return

    # Обрабатываем выбор героя
    if result == "choice_1":
        $ hero = Hero(
            name = "Мильтон", 
            full_name = "брат Мильтон", 
            prof = PROF.MONK, 
            state = STATE.HEALTHY, 
            mercy = 2, 
            reason = 4, 
            aspect = 2, 
            control = 8, 
            image = "images/chars/hero_milton_idle.png",
            portrait = "images/chars/hero/hero_milton_portrait.png",
            color="#ce0c0c")
        
        narrator "Когда-то ты уже жил в Морвейне — как монах Ордена."
        narrator "Через пару лет обучения в столице ты почти убедил себя, что тихие стоны, доносящиеся из-под собора, были лишь кошмаром."
        narrator "Но прошлой ночью ты снова услышал их во сне."
    elif result == "choice_2":
        $ hero = Hero(
            name = "Фальк", 
            full_name = "доктор Фальк", 
            prof = PROF.DOCTOR, 
            state = STATE.HEALTHY, 
            mercy = 6, 
            reason = 7, 
            aspect = 0, 
            control = 3, 
            image = "images/chars/hero_falk_idle.png", 
            portrait = "images/chars/hero/hero_falk_portrait.png",
            color="#ce0c0c")

        narrator "Первого пациента привели к тебе четыре дня назад. Мальчик не просыпался двое суток. Во сне он неустанно повторял одно слово на неизвестном языке."
        narrator "Через день он исчез из палаты."

    $ hero_selected = True

    narrator "Морвейн не был похож на другие города королевства Эстервальд."
    narrator "Даже глубокой ночью в переулках часто горел свет. Люди ходили быстро, редко смотрели друг другу в глаза и запирали двери до наступления темноты."
    narrator "Над городом возвышался собор Ордена. Звон его колоколов определял жизнь Морвейна: когда работать, когда молиться, когда оставаться дома."
    narrator "Говорили, что монахи могут распознать лунатика еще до того, как тот впервые заговорит во сне."
    narrator "Лунатики, спящие, сомнабулы — так называли тех, кого поразило проклятие сна."
    narrator "И это проклятие, если верить слухам, распространялось по городу подобно пульсирующему гнойнику."
    narrator "Под улицами Морвейна тянулись старые катакомбы. Некоторые тоннели давно обрушились. Некоторые — исчезли с карт Ордена."
    narrator "Люди перешептывались между собой, что из этих катакомб по ночам можно услышать шаги там, где уже много лет никого не было."
    narrator "Казалось, что сон все сильнее проникает в Морвейн. И нынешний настоятель Ордена просил твоей помощи."

    menu:
        "Отправиться в собор":
            jump morvein_streets

label morvein_streets:
    $ hard_fade("morvein_streets", show_gui=False)

    narrator "Чем глубже ты заходишь в город, тем больше удушливое чувство всеобщего страха проникает в тебя."
    narrator "Люди стараются не задерживаться на улицах. Некоторые, заметив твой взгляд, сразу опускают голову."
    narrator "У перекрестка ты замечаешь человека, неподвижно стоящего под дождем с закрытыми глазами."
    narrator "Словно почуяв твое присутствие издалека, он начинает медленно идти в твою сторону."
    narrator "Ты ускоряешь шаг и переходишь на соседнюю улицу, продолжая движение вперед."

    $ hard_fade(scene_name="morvein_streets", delay=2.0, show_gui=False)

    narrator "Из приоткрытого окна доносится жаркий спор."
    narrator "Один из голосов доказывает другому, что мальчика давно стоило отвести в собор, пока он был в сознании."
    narrator "Когда ты проходишь мимо, диалог резко затихает."
    narrator "Но уже через несколько метров спор возобновляется за твоей спиной."

    $ hard_fade(scene_name="morvein_streets", delay=2.0, show_gui=False)

    narrator "Рядом двое прохожих торопливо проходят мимо тебя."
    narrator "Один из них громко шепчет второму, что в старых катакомбах снова творится что-то странное."
    narrator "Второй лишь скептически фыркает и предлагает спутнику замолчать."
    narrator "Впереди, со стороны собора, звучит полуденный колокол, на этот раз ближе. Гул медленно прокатывается по улицам Морвейна."
    narrator "Кажется, будто город на мгновение замирает, прислушиваясь к нему."
    narrator "Дойдя до конца тесной улицы, ты видишь, как впереди сквозь туман проступают темные шпили собора."

    if hero.prof == PROF.MONK:
        narrator "Настало время вернуться в родную обитель."
    else:
        narrator "Настало время отправиться в грозную обитель Ордена — самое главное здание города."

    jump temple_outside   

label temple_outside:
    $ hard_fade("temple_outside", show_gui=False)

    narrator "Собор Ордена возвышается над Морвейном, словно исполинский часовой."
    narrator "Его башни теряются в тумане, а дождь скрывает рисунки на витражах от случайного взгляда." 
    narrator "Ворота собора настолько высоки, что человек рядом с ними кажется ребенком. Тяжелые створки покрывают резные узоры, напоминающие волны беспокойного моря."
    narrator "По слухам, под самим собором находятся старые залы, куда не допускают даже послушников."
    narrator "И что иногда, если долго стоять у стен в полной тишине, можно услышать пение, доносящееся откуда-то снизу."
    narrator "Когда ты подходишь к храму ближе, колокола над городом снова начинают тревожно звучать, словно предупреждая Морвейн о чьем-то прибытии."
    narrator "У стены собора сидит сгорбленный калека, укрывшись рваным плащом от дождя."
    narrator "Одна его нога заканчивается ниже колена, а пальцы дрожат так сильно, будто он никак не может согреться. Перед ним лежит деревянная чаша, почти пустая."
    narrator "Когда ты проходишь мимо, он обращает на тебя свой полуслепой взгляд, устремленный куда-то вдаль."

    $ dream_char("beggar default")

    if hero.prof == PROF.MONK:
        narrator "Заметив на твоих одеждах знаки Ордена, попрошайка с почтительным ужасом отходит в сторону, пропуская тебя к дверям собора."
    else:
        beggar "Они снова поют сегодня ночью..."
        beggar "Значит, кто-то опять не проснется..."
        beggar "Опять..."

        narrator "Калека вдруг замолкает и резко подскакивает к тебе, обдавая тошнотворным гнилым дыханием."
        narrator "Его руки с черной кромкой под ногтями хватают тебя за рубашку, почти что требуя подаяния."

        menu:
            "Бросить монетку":
                narrator "Преодолев позыв тошноты, ты из жалости кидаешь несчастному монетку в его почти пустую чашу."
                narrator "Взгляд нищего на секунду становится осмысленным, и он благодарно кивает."
                $ add_stat(hero, "mercy", 1)
                $ beggar_flag_help = True
            "Отстраниться и пойти дальше":
                narrator "Ты отскакиваешь назад и брезгливо обходишь калеку сбоку."
                narrator "Не хватало еще заразиться от него чем-нибудь."

    narrator "Оставив калеку за спиной, ты входишь в едва приоткрытые двери собора."

    jump temple_inside

label temple_inside:
    $ change_music("<from 52.0>audio/temple.mp3")
    $ hard_fade("temple_inside", show_gui=False)

    narrator "Внутри собора значительно темнее, чем на улице. Высокие своды теряются где-то наверху, за дымом свечей и серыми тенями."
    narrator "Шаги внутри звучат непривычно глухо, будто камень под ногами поглощает всякий звук."
    narrator "У алтаря вдалеке ходят монахи в поизносившихся одеяниях. Некоторые молятся, некоторые будто спят прямо стоя, неподвижно склонив головы."
    narrator "Двое братьев осторожно проводят через зал мальчика лет десяти. Ребенок идет босиком с закрытыми глазами, едва переставляя ноги."
    narrator "Когда один из монахов встряхивает его за плечо, мальчик никак не реагирует, словно находится где-то бесконечно далеко отсюда."
    narrator "Чуть дальше ты видишь, как один молодой послушник, несущий ведро воды, на мгновение останавливается посреди прохода."
    narrator "Его взгляд становится пустым, а ведро выскальзывает из рук, с глухим стуком ударяясь о пол."
    narrator "Лишь через несколько секунд он приходит в себя и поднимает упавшее ведро, словно стыдясь чужих взглядов."
    narrator "Где-то в глубине собора слышится негромкое и монотонное пение."
    narrator "Несколько голосов повторяют одну и ту же фразу снова и снова, словно убаюкивая ребенка."

    $ dream_char("stefan default")

    narrator "Из темноты впереди появляется фигура монаха."
    narrator "Высокий, болезненно бледный человек с глубоко запавшими глазами внимательно смотрит на тебя."

    stefan "Добро пожаловать, [hero.full_name]!" 

    if hero.prof == PROF.MONK:
        stefan "Сожалею, что мы были вынуждены прервать ваше обучение в столице."
        stefan "Но ситуация в городе чрезвычайно серьезная, нам потребуется помощь каждого брата."
    else:
        stefan "Я знаю, что вы в городе совсем недавно, но наслышан о вас и вашем опыте."
        stefan "Сожалею, что вашу блестящую карьеру омрачил этот трагический инцидент."
        stefan "Уверен, в том не было вашей вины — иногда воля рока вмешивается в наши планы."
        stefan "В любом случае, я уверен, что вы и сейчас прекрасно справляетесь с важнейшей из миссий — служением людям."
        stefan "Мы в этом с вами удивительно похожи, доктор."

    stefan "Полагаю, вы уже слышали о том, что происходит в Морвейне?"

    menu:
        "Рассказать о первых днях в городе":
            narrator "Ты рассказываешь отцу Стефану о первых впечатлениях от своего пребывания в городе."
            narrator "О повсеместном недоверии и опустившейся на Морвейн липкой паутине страха."
            narrator "Настоятель Ордена мрачнеет с каждым словом."
            stefan "Да, именно поэтому нам и понадобилась ваша помощь."
            narrator "Над вашей головой в очередной раз звучит колокол."
            stefan "К сожалению, сейчас я вынужден на время вас оставить — сегодняшняя служба требует моего участия."

    if hero.prof == PROF.MONK:
        stefan "Поэтому предлагаю вам подождать меня в моем кабинете на время службы."
        stefan "После этого я посвящу вас во все подробности происходящего."
        narrator "Отец Стефан легким кивком головы прощается на время и покидает вас."
        jump temple_stefan_office
    else:
        stefan "Поэтому предлагаю вам осмотреть больных в лазарете на время службы."
        stefan "После этого я посвящу вас во все подробности происходящего."
        narrator "Отец Стефан легким кивком головы прощается на время и покидает вас."
        jump temple_hospital
        
label temple_stefan_office:
    $ hard_fade("temple_stefan_office", show_gui=False)

    narrator "Кабинет отца Стефана — верховного настоятеля Ордена — удивляет тебя своей непритязательностью. Здесь полностью отсутствуют позолота и дорогая драпировка, которые украшали кабинет предыдущего наставника."
    narrator "Вместо этого комната встречает почти келейной строгостью: каменные стены, простая деревянная мебель и потертый ковер на полу."
    narrator "Главное место здесь занимают книги. Тяжелые, обтянутые кожей фолианты плотными рядами заполняют массивные стеллажи и буквально подпирают потолок своим весом."
    narrator "На дубовом столе царит рабочий хаос: стопки исписанной бумаги, раскрытые манускрипты и капли воска выдают колоссальный объем дел, в которых буквально тонет настоятель."
    narrator "Среди этого беспорядка особое внимание привлекает большая, раскинутая прямо по центру стола карта города. На ней чернилами грубо очерчиваются жилые районы Морвейна."
    narrator "Эти линии и пометки на полях складываются в пугающий рисунок. Схема как будто не отражает ни план застройки, ни военные маневры."
    narrator "Судя по всему, она показывает, как неостановимо, район за районом, город погружается в объятия сна."
    narrator "В ожидании отца Стефана ты берешь в руки лежащую на столе книгу и начинаешь чтение."
    narrator "Сквозь приоткрытый дверной проем доносится глухое пение хора."
    narrator "Оно сопровождало тебя с самого момента прибытия в собор и давно превратилось в привычный фоновый шум."
    narrator "Именно поэтому ты не сразу понимаешь, что именно изменилось."
    narrator "В какой-то момент до тебя доходит пугающее осознание: хор замолчал."
    narrator "Воздух в комнате мгновенно густеет от напряжения."
    narrator "Ты прислушиваешься к тому, что происходит в главном зале собора."
    narrator "И через несколько секунд из глубины собора доносятся первые встревоженные крики."

    jump awakening_temple

label temple_hospital:
    $ hard_fade("temple_hospital", show_gui=False)

    narrator "Когда отец Стефан оставляет тебя, один из священников провожает тебя в душное пространство лечебницы."
    narrator "Вдоль стен тянутся наспех скроенные койки, занятые спящими людьми разного возраста."
    narrator "Некоторые тихо бормочут в бреду, другие лежат совершенно неподвижно, словно погрузившись в безвременье."
    narrator "Осматривая больных, ты быстро понимаешь, почему местные считают происходящее проклятьем."
    narrator "Симптомы у всех одинаковы: крайнее истощение, исхудавшие руки с резко проступающими синими венами и глубокие темные круги под глазами."
    narrator "Чуть поодаль несколько монахов ухаживают за детьми, которых болезнь поразила сильнее всего."
    narrator "Один мальчик внезапно садится на постели, произносит несколько бессвязных слов и тут же падает обратно, так и не придя в сознание."
    narrator "Сквозь открытый дверной проем доносится глухое пение хора."
    narrator "Оно сопровождало тебя с самого момента прибытия в собор и давно превратилось в привычный фоновый шум."
    narrator "Именно поэтому через некоторое время ты не сразу понимаешь, что именно изменилось."
    narrator "В какой-то момент до тебя доходит пугающее осознание: хор замолчал."
    narrator "Воздух в лазарете мгновенно густеет от напряжения."
    narrator "В возникшей тишине несколько спящих пациентов одновременно принимают сидячее положение, чтобы встать с кровати."
    narrator "Один за другим они поднимаются на ноги, будто подчиняясь беззвучному приказу."
    narrator "И именно в этот момент из глубины собора доносятся первые встревоженные крики."

    jump awakening_temple   

label awakening_temple:
    $ change_music("<from 147.0>audio/epic_theme.m4a", fadeout=1.0, fadein=1.0)
    $ hard_fade("temple_inside", show_gui=False)

    narrator "Ты врываешься в главный зал собора, который уже охвачен паникой."
    narrator "Большинство прихожан в ужасе жмутся к стенам, не в силах пошевелиться." 

    $ dream_char("sleepwalkers default", [Transform(xcenter=0.5, yanchor=1.0, ypos=1.25)])

    narrator "В центре зала толпится несколько десятков спящих, среди которых и прихожане, и монахи, и певцы хора."
    narrator "С закрытыми глазами они медленно идут вперед, не реагируя ни на что вокруг."
    narrator "Ты слышишь, как в другом конце зала отец Стефан уже отдает приказы."

    stefan "Закройте двери! Не дайте им выйти в город!"

    $ hide_dream_char("stefan default")
    $ dream_char("sleepwalkers default", [Transform(xcenter=0.5, yanchor=1.0, ypos=1.25)])

    narrator "Один из монахов пытается остановить женщину в грязном белом платке, преградив ей путь, но та буквально опрокидывает его, продолжая идти вперед."
    narrator "Второй хватает за руку приведенного недавно мальчика, но тот вырывается с неожиданной силой и устремляется по направлению к выходу."
    narrator "Отец Стефан перебрасывает своих людей от одного прохода к другому, но лунатики продолжают возникать в разных частях собора и каждый раз обходят препятствия, будто заранее знают, где их встретят."
    narrator "Несколько братьев опрокидывают тяжелые деревянные скамьи поперек центрального нефа, превратив их в подобие баррикады."
    narrator "Спящих это не останавливает — они медленно перелезают через препятствия или сворачивают в боковые проходы, продолжая двигаться к выходу с пугающим упорством."
    narrator "Ты видишь, что у главных ворот, несмотря на приказ отца Стефана, царит неразбериха."
    narrator "Пока братья пытаются сдвинуть тяжелые створки, обезумевшая от страха толпа устремляется к незапертым дверям."
    narrator "Прихожане в панике наваливаются на створки, стремясь во что бы то ни стало покинуть собор и мешая монахам запереть ворота."
    narrator "К тому моменту, как братьям удается восстановить порядок и наконец захлопнуть двери, большая часть сомнамбул успевает покинуть собор вместе с паникующими горожанами."
    narrator "Осознав, что его план потерпел неудачу, отец Стефан устремляется к выходу из собора — вслед за лунатиками. Ты устремляешься за ним вслед."

    $ hide_dream_char("sleepwalkers default")

    jump morvein_from_temple

label morvein_from_temple:
    $ hard_fade("morvein_from_temple", show_gui=False)

    $ dream_char("stefan default")

    narrator "Вы с отцом Стефаном выбегаете на широкую площадку перед собором и замираете."
    narrator "Отсюда весь Морвейн [ 'наверняка ' if hero.prof == PROF.MONK else '' ] обычно лежит как на ладони, но сейчас его тесные улицы и крыши затапливает густой, словно молоко, туман, сквозь который едва пробиваются редкие уличные огни."
    narrator "Повсюду в этой зыбкой пелене угадывается движение — размытые силуэты сомнабул медленно тянутся из глубин переулков, сливаясь в длинные, безмолвные потоки."

    menu:
        "Что нам делать?":
            "Отец Стефан не отвечает. Его взгляд прикован к людям вдалеке."
            "По его остекленевшим глазам ты понимаешь: он впервые не знает, что происходит..."

    $ hide_dream_char("stefan default")
    $ dream_char("beggar standing")

    narrator "Из туманной пелены прямо перед вами возникает силуэт нищего — того самого, которого ты видел у входа в собор."
    narrator "С закрытыми глазами он безмолвно шагает в вашу сторону, приближаясь почти вплотную."
    narrator "Отец Стефан нетерпеливо заносит руку, чтобы оттолкнуть бродягу, но калека резко размахивается своим массивным костылем."
    narrator "Тяжелое дерево с глухим стуком врезается настоятелю точно в висок — и отец Стефан падает на землю как подкошенный."
    narrator "Бродяга замирает над неподвижным телом, а затем медленно поворачивает голову в твою сторону."

    if beggar_flag_help:
        narrator "В последний момент в пустом взгляде калеки что-то меняется. Словно узнав тебя, он в замешательстве замирает."
        narrator "Через секунду его силы иссякают, и он замертво валится на брусчатку."

        $ hide_dream_char("beggar standing")
        $ hard_fade("morvein_from_temple", delay=1.0, show_gui=False)

        narrator "Какое-то время ты просто неподвижно стоишь, пытаясь перевести дух и унять дрожь в руках."
        narrator "У твоих ног неподвижно лежит отец Стефан. Из глубокой раны на его виске струится кровь — настоятель дышит, но дышит тяжело и редко."

        menu:
            "Спасти отца Стефана":
                $ hard_fade("temple_outside", show_gui=False)
                $ stefan_saved_flag = True

                "С трудом взвалив грузное тело священника на плечи, ты ковыляешь обратно к собору."
                "Засов на главных воротах уже задвинут, но, услышав твой отчаянный стук, монахи поспешно приоткрывают тяжелую створку."
                "Они подхватывают бесчувственного настоятеля, а у тебя внутри словно обрывается тугая струна."
                "Ноги подкашиваются. Последнее, что ты видишь перед тем, как провалиться в темноту — холодное, серое небо Морвейна..."
    else:
        narrator "Калека резко наклоняется, подхватывает с земли обломок брусчатки и с силой швыряет его тебе прямо в лицо."
        narrator "Тяжелый камень с неприятным звуком врезается в твою скулу. Издав протяжный хрип, нищий тут же падает навзничь, окончательно лишившись сил."
        
        $ hide_dream_char("beggar standing")

        show screen blood_overlay(hero)
        $ hero.state = STATE.INJURED

        narrator "В глазах вспыхивают искры, а рот наполняется солоноватым вкусом крови. Ты чувствуешь, как разум стремительно заволакивает черная пелена."
        narrator "Ноги подкашиваются. Последнее, что ты видишь перед тем, как провалиться в темноту — холодное, серое небо Морвейна..."

    stop music fadeout 5.0
    $ fade_to_black(fade_time=3.0, pause_time=5.0, hide_screen="blood_overlay")

    $ renpy.take_screenshot()
    $ renpy.save("1-1", "Начало 1 акта")

    jump act_1_hospital_before_start
        
