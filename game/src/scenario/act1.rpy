# Первый акт
label act_1_hospital_before_start:
    play music "hospital.mp3" fadein 5.0

    $ hard_fade("temple_bed_view", 5.0, show_gui=False)

    $ hero.state = STATE.HEALTHY

    narrator "Ты открываешь глаза и несколько секунд смотришь в деревянный потолок."
    narrator "В голове шумит, а каждый вдох отзывается тупой болью в голове."
    narrator "Спустя несколько секунд ты понимаешь, что находишься в отдельной палате храмовой лечебницы."
    narrator "Справа от тебя сидит незнакомый человек в монашеской рясе. Заметив движение, он откладывает книгу и поднимается на ноги."
    
    $ dream_char("mattias default")

    mattias "О, ты снова с нами, соня."
    mattias "Я брат Маттиас, присматриваю за этой лечебницей."
    mattias "И за тобой, пока ты не поправишься."
    narrator "Ты видишь легкую улыбку на его лице, которая кажется неуместной в такой обстановке, но выглядит очень искренней."

    menu:
        "Сколько я уже здесь? И что с отцом Стефаном?":
            mattias "Ты здесь уже пару дней. К счастью, твои раны оказались не слишком серьезными. Через пару дней ты уже полностью поправишься."
            narrator "Выражение лица Маттиаса мрачнеет."
            mattias "Что касается отца Cтефана — он жив. Но травма очень тяжелая, мы боремся за его жизнь все это время."
            mattias "Орден не может позволить себе потерять такого человека, как он."
            mattias "Всеми делами сейчас временно управляет совет Ордена."
    
    if hero.prof == PROF.DOCTOR:
        menu:
            "Совет Ордена?":
                mattias "Да, это группа старших братьев, которые принимают решения в отсутствие отца Стефана."

    mattias "Им пришлось действовать быстро и решительно, чтобы навести порядок после произошедшего."
    mattias "Сотни людей бесследно исчезли этой ночью."
    mattias "Все выходы из города сейчас закрыты, а на улицах введен комендантский час."
    mattias "И еще одно."
    mattias "Совет хочет встретиться с тобой. Ведь ты последний, кто видел отца Стефана в сознании."
    mattias "А сейчас — отдыхай. Продолжим наш разговор позднее."

    hide mattias default
    with dissolve

    call dream_scene(
    [
        "Ты слышишь колокола и шум прибоя...",
        "Они звучат все ближе...",
    ],
    "stefan horror",
    [
        "Они уже ушли.",
        "Ты ещё можешь их догнать...",
        "Нет, ты уже не сможешь!",
        "Ты опоздал...",
        "Когда настанет час — бойся Прилива!"
    ],
    False)

    if hero.aspect <= 2:
        $ add_stat(hero, "aspect", 1)
    
    $ dream_char("mattias default", [center])

    narrator "Брат Маттиас встревоженно подбегает к тебе."
    mattias "Что случилось?"
    mattias "Твои крики были слышны на весь собор."
    narrator "Ты рассказываешь священнику об увиденном тобой кошмаре."
    narrator "При воспоминаниях об отце Стефане с его белыми зрачками и жуткой ухмылкой по твоему телу бежит холодная дрожь."
    if(hero.prof == PROF.MONK):
        narrator "В твоей памяти всплывают жуткие сны, которые ты уже видел когда-то в стенах собора."
    elif(hero.prof == PROF.DOCTOR):
        narrator "Никогда в своей жизни ты не видел таких жутких снов."
    narrator "Монах ободряюще сжимает твое плечо."
    mattias "В последнее время люди видят кошмары все чаще..."
    narrator "Отец Маттиас протягивает тебе пузырек с искрящейся желтой жидкостью."
    mattias "Вот, возьми."
    mattias "Если ужасы начнут одолевать тебя, то выпей это зелье."
    if(hero.prof == PROF.MONK):
        mattias "Сам знаешь, как Орден дорожит этими эликсирами."
    elif(hero.prof == PROF.DOCTOR):
        mattias "Используй его с умом. Орден обычно не раздает эти эликсиры никому, кроме самих братьев."
    mattias "Такими темпами придется раздавать их всем жителям города..."
    narrator "В воздухе повисает долгое молчание, сопровождаемое лишь дыханием твоего собеседника."
    narrator "Ты чувствуешь, что сознание снова начинает покидать тебя."
    narrator "Маттиас, заметив это, беззвучно отступает от кровати и выходит за дверь."
    narrator "Последнее, что ты слышишь перед погружением в сон, это звук удаляющихся шагов..."

    hide mattias default
    with dissolve

    $ hard_fade("temple_bed_view", show_gui=False)
    
    narrator "Проснувшись снова, ты чувствуешь, что силы почти вернулись к тебе."
    narrator "Голова всё ещё ноет, но кошмар отступил, оставив после себя лишь смутное беспокойство."
    narrator "Некоторое время ты лежишь неподвижно, глядя в потолок лечебницы и думая о произошедшем."
    narrator "Поднявшись на ноги спустя пару десятков минут, ты замечаешь, что за окном уже давно рассвело. Пора действовать."

    $ hard_fade("temple_inside", show_gui=False)

    narrator "Собор сильно преобразился за время, пока ты был без сознания."
    narrator "Повсюду снуют братья Ордена с книгами и свитками в руках."
    narrator "Помещение наводнили храмовые стражи: они стоят у алтаря, у выхода и в тени боковых проходов."
    narrator "Неизменным остался лишь хор, который снова поет свою размеренную песнь."
    narrator "Ты чувствуешь, что сам воздух гудит от возникшего в городе напряжения."
    narrator "Осталось лишь понять, что делать дальше."
    narrator "Пойти ли по горячим следам, попытавшись найти пропавших лунатиков."
    narrator "Либо же, как говорил брат Маттиас, отправиться на встречу с Советом."
    narrator "Возможно, в архивах Ордена содержатся какие-то сведения, которые могли бы сейчас помочь."

    $ renpy.take_screenshot()
    $ renpy.save("1-2", "Начало 1 акта")

    jump act_1_start

label act_1_start:
    if hero.prof == PROF.MONK:
        $ inventory_items = [
            InvItem("coins", "Золото", "images/misc/coins.png", "Золотая марка Морвейна. Причина людского раздора во все времена.", 100),
            InvItem("potion_hp", "Зелье исцеления", "images/misc/potion.png", "Колба с мерцающей красной жидкостью внутри. Исцеляет даже самые тяжелые раны.", 1),
            InvItem("potion_energy", "Зелье бодрости", "images/misc/potion_energy.png", "Редкое зелье, изготавливаемое алхимиками Ордена из черного вереска. Выпей - и кошмары отступят.", 1),
            InvItem("potion_poison", "Яд", "images/misc/potion_poison.png", "Яд", 1)
        ]
    else:
        $ inventory_items = [
            InvItem("coins", "Золото", "images/misc/coins.png", "Золотая марка Морвейна. Причина людского раздора во все времена.", 300),
            InvItem("potion_hp", "Зелье исцеления", "images/misc/potion.png", "Колба с мерцающей красной жидкостью внутри. Исцеляет даже самые тяжелые раны.", 10),
            InvItem("potion_energy", "Зелье бодрости", "images/misc/potion_energy.png", "Редкое зелье, изготавливаемое алхимиками Ордена из черного вереска. Выпей - и кошмары отступят.", 0),
            InvItem("potion_poison", "Яд", "images/misc/potion_poison.png", "Яд", 2)
        ]

    narrator "Настало время выбора"

    $ renpy.pause(2.0, hard=True)
    show screen gui
    with dissolve(2.0)

    menu:
        "Искать улики в городе":
            jump act_1_investigation_streets
        "Отправиться к Совету":
            jump act_1_archives_council

label act_1_investigation_streets:
    $ change_music("audio/morvein_explore.mp3")
    $ hard_fade("morvein_streets")

    narrator "Через несколько минут ты снова оказываешься на знакомой улице."
    narrator "Остановившись под навесом старой лавки, ты думаешь, с чего начать расследование ночного исхода сомнабул."
    narrator "Слепое блуждание по переулкам Морвейна вряд ли приведёт к чему-то, кроме новых слухов."
    narrator "Но если посмотреть иначе, то в закрытом городе, где люди боятся говорить открыто, зацепку можно найти среди самых невероятных сплетен."
    narrator "И ты знаешь идеальное место, которое полнится пересудами и днем, и ночью..."

    menu:
        "Отправиться в таверну":
            jump act_1_investigation_tavern

label act_1_investigation_tavern:
    $ hard_fade("morvein_tavern")

    narrator "Таверна полна людьми. Застравшие в городе возницы, торговцы, пьяные стражники — все горячо увлечены обсуждением произошедшего."
    narrator "Ты выбираешь место у стойки и заказываешь себе кружку местного горького эля."
    narrator "Опустошив ее в мгновение ока, ты заказываешь еще одну и начинаешь распрашивать хозяина о витающих в воздухе слухах."
    narrator "Трактирщик молча протирает грязные кружки, делая вид, что не слышит твоих вопросов."
    narrator "Лишь когда кидаешь на стол несколько золотых монет, тот незаметно кивает в сторону столика в темном углу зала."
    narrator "Там, почти сливаясь с тенью, сидит человек в низко надвинутом капюшоне."
    narrator "Ты просишь трактирщика налить тебе еще пинту эля, после чего идешь с двумя кружками к незнакомцу."
    narrator "Подойдя к его столу, ты молча садишься напротив него и протягиваешь ему один из бокалов."
    narrator "Незнакомец поднимает голову и пронзительно смотрит тебе в глаза, словно приглашая начать беседу."

    menu:
        "Спросить о слухах":
            narrator "Незнакомец едва кивает, не произнося ни слова."
            narrator "Он медленно встает из-за стола, укутываясь в плащ, и жестом приглашает тебя следовать за ним."

    jump act_1_investigation_well_alley

label act_1_investigation_well_alley:
    $ hard_fade("morvein_well_alley")

    narrator "Ты следуешь за фигурой в плаще по узким переулкам квартала мастеров." 
    narrator "Незнакомец идёт впереди, не оглядываясь, и вскоре выводит тебя к старому колодцу в одном из заброшенных дворов."
    narrator "Камни вокруг колодца покрыты мхом, а железная цепь давно почернела от ржавчины. Из глубины тянет влажным холодом."
    narrator "Твой спутник молча кивает в сторону колодца, словно приглашая заглянуть внутрь. Ты подходишь ближе."
    narrator "На первый взгляд, внутри нет ничего, кроме темноты и слабого запаха стоячей воды."

    menu:
        "Посмотреть вниз": 
            call dream_scene(
            [
                "Ты слышышь внизу следы босых ног ...",
                "Детский шепот заполняет твою голову..."

            ],
            "boy horror",
            [
                "Оно зовет нас...",
                "Иди с нами...",
                "Скоро печать будет сорвана..."
            ],
            False)

    $ add_stat(hero, "aspect", 1)

    $ hard_fade("morvein_well_alley")

    if hero.control > 5:
        narrator "В последний момент ты приходишь в себя и с ужасом понимаешь, что еще секунда — и ты упал бы головой вниз."
        narrator "Ты поспешно отстраняешься назад и разворачиваешься, приваливаясь спиной к колодцу."
        narrator "Незнакомца нигде не видно.."
        narrator "Внезапно перед тобой с испуганным возникает молодой паренек в поношенном рубище."
        narrator "Господин, меня послал за вами хозяин. Он сразу почуял неладное, когда вы молча ушли со стеклянным взглядом, не расплатившись."
        narrator "Вы скверно выглядите, пойдемте в таверну. Хозяин о вас позаботится."

        jump act_1_investigation_after_well
    else:
        call dream_scene(
        [
            "К шепоту мальчика присоединяется голос девочки..."
        ],
        "girl horror",
        [
            "Не сопротивляйся...",
            "Иди к нам...",
            "Все ответы ждут внизу..."
        ],
        [],
        True)

        $ hard_fade("morvein_well_inside")

        $ add_stat(hero, "aspect", 1)

        narrator "Ты приходишь в себя на дне колодца от осознания острой боли."
        narrator "Ощупав голову, ты чувствуешь, что оттуда идет кровь..."
        narrator "Время на исходе..."

        $ hero.state = STATE.GRAVELY

        $ renpy.pause(20.0, modal=True, hard=True)

        if hero.state == STATE.HEALTHY:
            narrator "Ты принимаешь целебный отвар, заставив боль на время отступить."
            narrator "Спустя несколько секунд ты видишь перед собой веревку."

    jump act_1_investigation_after_well

label act_1_investigation_after_well:
    $ hard_fade("morvein_tavern")

    narrator "Ты возвразаешься в таверну с Альбертом."
    narrator "Ты рассказываешь трактирщику Виллему об увиденном тобой."
    narrator "Тот с ужасом припоминает, что слышал той ночью какие-то звуки возле колодца неподалеку."
    narrator "По лицу героя трактирщик понимает, что герой намерен туда отправиться - и просит его подготовиться."
    narrator "Герой отправляется к торговцу."

    jump act_1_investigation_merchant_shop

label act_1_investigation_merchant_shop:
    $ hard_fade("morvein_merchant_shop")

    narrator "Ты начинаешь торговлю."

    call screen merchant_shop

    narrator "Ты покупаешь все необходимо для спуска."
    narrator "Ты завершаешь торговлю"
    narrator "Ты отправляешься к колодцу."

    jump act_1_investigation_well_descent

label act_1_investigation_well_descent:
    $ hard_fade("morvein_well_alley")

    "Ты готовишься спуститься в колодец."
    "Ты спускаешься в колодец."

    jump act_1_investigation_inside_well

label act_1_investigation_inside_well:
    $ hard_fade("morvein_inside_well")

    narrator "Ты внути колодца."
    narrator "Ты видишь внутри арку со странными символами, которые почти потухли."
    narrator "Ты видишь под аркой тяжелую каменную плиту, котрая недавно явно двигалась."
    narrator "У тебя не получается ее ни открыть, ни сдвинуть с места."
    narrator "Ты делаешь предположение, что она открывается только ночью."

    $ hard_fade("morvein_well_alley")

    narrator "Ты вылезаешь из колодца."
    narrator "Тебе возвращаешься в таверну."

    jump act_1_investigation_tavern_meeting

label act_1_investigation_tavern_meeting:
    $ hard_fade("morvein_tavern")

    narrator "Ты идешь с Альбертом в таверну."
    narrator "Ты обсуждаешь с ним и Виллемом увиденное."

    $ dream_char("rykard_guard_unarmed")

    narrator "К вам посаживается незнакомец."
    narrator "Ты спрашиваешь, почему он заманил тебя в ловушку."
    narrator "Тот сухо говорит, что не имеет привычки попусту ходить по бедным кварталам."
    narrator "Он продолжает, что его хозяин внимательно следил за действиями героя."
    narrator "Он вручает приглашение ко встрече с Рикардом."

    jump act_1_rykard_gang_counter

label act_1_archives_council:
    $ change_music("audio/temple_council.mp3")
    $ hard_fade("temple_council_enter")

    $ dream_char("temple guard defalut", [center])

    narrator "Ты подходишь к высоким дверям, которые охраняет угрожающего вида храмовый страж."
    narrator "Он одаривает тебя недовольным взглядом, словно его отвлекли от чего-то важного, после чего нехотя молча приоткрывает двери."
    narrator "Ты входишь в зал и спустя пару секунд слышишь за собой грохот закрывающихся тяжелых створок."

    $ hard_fade("temple_council")
    hide temple guard default with dissolve

    narrator "Впереди от тебя, за массивным каменным столом, сидят трое старших братьев Ордена."
    narrator "В полумраке их лица кажутся высеченными из серого камня."
    narrator "Несколько мгновений никто не произносит ни слова."
    narrator "Затем сидящий по центру монах встает и скрипучим голосом обращается к тебе."

    $ dream_char("edmund default", [center])

    edmund "Доброе утро, [hero.full_name], мы вас ждали."
    edmund "Перейду сразу к делу: вы были последним, кто видел отца Стефана в сознании."
    edmund "И у нас есть к вам пара вопросов."
    narrator "Ты рассказываешь Совету о событиях той роковой ночи."
    narrator "О встрече с отцом Стефаном, об исходе спящих, о напавшем на настоятеля нищем."
    narrator "Старшие братья внимательно слушают тебя, периодически переглядываясь между собой."
    edmund "Что же, ваши слова звучат убедительно."
    edmund "Если у нас и были какие-то подозрения, то вы их развеяли."
    edmund "Возможно, у вас есть какие-то вопросы?"

    menu:
        "Узнать о доступе к архивам Ордена":
                narrator "Ты спрашиваешь о возможности изучить хроники Ордена."
                narrator "В прошлом братья уже однажды справились к проклятием сна."
                narrator "Возможно, истории того времени дадут ответы на новые вызовы."

    if (hero.prof == PROF.MONK or stefan_saved_flag):
        if (hero.prof == PROF.MONK):
                edmund "Вы получите доступ к архиву, [hero.full_name]. Обычно это требует специального разрешения, но с учетом ситуации — Совет дает вам доступ."
                edmund "Но сперва нам потребуется ваша помощь."
                edmund "Нам стоило немалых усилий восстановить работу хора после недавних событий."
                edmund "К сожалению, один из наших главных солистов пропал после той ночи, мы до сих пор не можем найти его."
                edmund "Все братья сейчас заняты больными, поэтому этим придется заняться вам."
                edmund "Приступайте."

                jump act_1_singer_cell

        else:
            edmund "Вы спасли отца Стефана."
            edmund "Что же, совет доверяет вам, поэтому вы получите доступ к архиву."
            edmund "Покажите эту печать брату Корнелиусу, он вас впустит."

            jump act_1_archives_explore

    else:
        edmund "У Совета нет причины доверять незнакомцам, хотя отец Стефан за вас и ручался."
        edmund "Но всякое доверие можно заслужить."
        edmund "Мы слышали, в городе появился торговец фальшивыми зельями бодрствования."
        edmund "Сами понимаете, какое помешательство в городе начнется, если эта дрянь начнет распространяться."
        edmund "Сумеете разобраться с проблемой — получите доступ в наши архивы."
    
        jump act_1_archives_agatha_quest


label act_1_singer_cell:
    $ hard_fade("temple_singer_cell")

    narrator "Герой обследует келью певца."
    narrator "В келье герой находит спрятанный дневник."

    menu:
        "Прочитать дневник":
            narrator "Герой читает дневник певца."

    narrator "Из дневника герой узнает, что певцу со временем начало становиться хуже."
    narrator "В дневнике сказано, что пара его братьев из хора исчезла."
    narrator "Певец выкрал из секретной секции архива записи о хоре."
    narrator "Из архивных записей певец узнал, что пропавшие певцы, возможно, находятся под собором."

    $ add_inventory_item(
        InvItem(
            "singer_notes",
            "Записи певца",
            "images/misc/manuscript.png",
            "Дневник певца и выкраденные архивные записи о хоре.",
            1
        )
    )

    narrator "Герой забирает дневник и архивные записи."

    jump act_1_before_underground_choir

label act_1_before_underground_choir:
    $ hard_fade("temple_before_underground_choir")

    narrator "Герой приходит к проходу под собор."
    narrator "Обычно этот проход охраняется."
    narrator "Сейчас проход никем не охраняется."
    narrator "Стража нигде нет."
    narrator "Герой идет в подземный проход."

    jump act_1_underground_choir

label act_1_underground_choir:
    $ hard_fade("temple_underground_choir")

    narrator "Герой выходит в подземный зал."
    narrator "Посреди зала стоят окаменевшие фигуры."
    narrator "Среди них герой видит пропавшего певца."
    narrator "У ног певца лежит убитый страж."
    narrator "Певец плачет."
    narrator "Певец говорит, что теперь узнал правду."
    narrator "Певцы хора со временем деревенеют."
    narrator "После этого их отводят вниз."
    narrator "Их используют для поддержания резонанса хора."
    narrator "Со временем певцы каменеют окончательно."
    narrator "Певец передает герою записи об этом."
    narrator "Певец говорит, что для него все кончено."

    $ add_inventory_item(
        InvItem(
            "choir_resonance_notes",
            "Вырванные страницы хроники",
            "images/misc/manuscript.png",
            "Вырванные страницы о том, что окаменевших певцов используют для поддержания резонанса хора.",
            1
        )
    )

    $ choir_notes_found_flag = True

    if hero.control > 10:
        $ singer_saved_flag = True

        narrator "Герой замечает, что певец пытается убить себя."
        narrator "Герой успевает схватить певца."
        narrator "Герой забирает окровавленный кинжал певца."
        narrator "Герой отводит певца в Совет."
    else:
        $ singer_saved_flag = False

        narrator "Герой слишком поздно понимает, что певец пытается убить себя."
        narrator "Певец убивает себя."
        narrator "Герой забирает окровавленный кинжал певца."
        narrator "Герой несет тело певца в Совет."

    $ add_inventory_item(
        InvItem(
            "bloody_dagger",
            "Окровавленный кинжал",
            "images/misc/bloody_dagger.png",
            "Кинжал пропавшего певца, испачканный кровью.",
            1
        )
    )

    jump act_1_singer_found

label act_1_singer_found:
    $ hard_fade("temple_council_enter")

    if singer_saved_flag:
        narrator "Герой приводит спасенного певца к Совету."
    else:
        narrator "Герой приносит тело певца к Совету."

    $ hard_fade("temple_council")

    if singer_saved_flag:
        narrator "Совет благодарит героя."
        narrator "Совет говорит, что позаботится о послушнике."
    else:
        narrator "Совет сокрушенно вздыхает."
        narrator "Совет просит оставить тело."
        narrator "Совет говорит, что тело заберут."

    menu:
        "Отдать вырванные страницы хроники и кинжал":
            narrator "Герой отдает Совету вырванные страницы хроники и окровавленный кинжал."
            $ remove_item("choir_resonance_notes")
            $ remove_item("bloody_dagger")

        "Оставить страницы и кинжал себе":
            narrator "Герой оставляет вырванные страницы хроники и окровавленный кинжал себе."

    narrator "Совет говорит герою, что теперь он может идти в архив."

    jump act_1_archives_explore

label act_1_archives_explore:
    $ hard_fade("temple_archives")

    narrator "Ты заходишь в пыльное простанство архивов и видишь перед собой ветхого подслеповатого старика."
    narrator "Кажется, что древние книги, уходящие бесконечным рядами вдаль, приходятся ему ровесниками."
    narrator "С удивительной для такого пожилого человека пружинящей попыткой, он подходит к вам."

    $ dream_char("cornelius default", [center])

    cornelius "Добрый день, юноша!"
    cornelius "Я слышал, Совет допустил вас до моей обители. Слышал и то, что вы хотите найти в этих древних записях упоминания о предыдущем кризисе в Морвейне."
    cornelius "Помяните мое слово: все решения невзгод дня текущего можно найти в ответах прошлого."
    cornelius "Но простите старику его занудные речи."
    cornelius "Думаю, я смогу вам помочь в вашем расследовании."
    narrator "Архивариус кладёт перед два тяжёлых тома, каждый из которых перевязан потемневшей кожаной лентой."
    cornelius "Не буду вам мешать погружаться в прошлое."

    $ hide_dream_char("cornelius default")

    menu:
        "Взять первый том":
            $ add_inventory_item(
                InvItem("order_history_1", 
                "О смуте сна в Морвейне, том I", 
                "images/misc/manuscript.png",  
                "Первый том хроники Морвейна, посвященный древней истории города и истокам прошлого кризиса сна.",
                1) 
            )

            narrator "На обложке первого тома выведено: «О смуте сна в Морвейне»."
            narrator "Дата под названием почти стёрлась, но бумага выглядит так, будто этим записям больше нескольких сотен лет."
            narrator "Первые страницы хроники рассказывают об эпохе, когда Морвейном ещё управляли древние роды."
            narrator "Ты видишь, как велика была роль этих семейств в политической и религиозной жизни города."
            narrator "Дальше по тексту встречаются жуткие описания устраиваемых знатью города жертвоприношений, в том числе и человеческих — в исключительных случаях."
            narrator "Ты проводишь немало времени, вчитываясь в кровавые подробности прошлого."
            narrator "Следом идет раздел с описанием первого кризиса сна в Морвейне, который горожане между собой называли «Приливом»."
            narrator "Сначала речь идёт о странных кошмарах, которые со временем становятся всё более реальными и неотвратимыми."
            narrator "Затем появляются сообщения о людях, которые начинают ходить во сне, покидают свои дома и бесследно исчезают до рассвета."
            narrator "Тон отчетов с каждой страницей становится все более тревожным. Исчезновения учащаются, а среди жителей начинает распространяться паника."
            narrator "Ближе к концу книги ты находишь первые записи об истоках ттого, что впоследствии назовут Орденом Ночи — или просто Орденом."
            narrator "Неспособность знати Морвейна справиться с кризисом привела к возникновению религиозного культа, призывавшего остановить жертвоприношения."
            narrator "Часть древних родов поддержала новое течение, утратив веру в собственную способность справиться с распространяющимся ужасом."
            narrator "Другая же половина знатных домов выступила резко против бунтовщиков. Город был на пороге войны."
            narrator "Ты перелистываешь книгу на следующую страницу и видишь, что книга резко обрывается на одном предложении"
            narrator "Последняя страница хроники завершается словами: «После принятия чрезвычайных мер распространение сна было остановлено»."
            narrator "Ты несколько раз перечитываешь эти строки, явно ожидая подробностей."
            narrator "После десятков страниц с описанием древней истории города, человеческих жертв и первого Прилива такое описание кажется непривычно коротким."
            narrator "Возможно, во втором томе будет больше подробностей."

    with fade

    menu:
        "Перейти к следующему тому":
            $ add_inventory_item(
                InvItem("order_history_2", 
                "О смуте сна в Морвейне, том II", 
                "images/misc/manuscript.png",  
                "Второй том хроники Морвейна, посвященный преодолению прошлого кризиса сна. Многие записи отсутствуют или изменены.",
                1)
            )

            narrator "Следующий том хроники посвящен первым годам существования Ордена. Ты быстро находишь раздел, в котором рассказывается о преодолении кризиса."
            narrator "Однако уже на первых строчках становится заметно, что с документами что-то не так. Некоторые строки аккуратно замазаны чернилами, а в отдельных местах остались лишь пустые промежутки."
            narrator "В одном из отчётов сохранилось описание подготовки чрезвычайных мер. Следующая страница должна объяснять, что произошло дальше, но вместо текста ты находишь лишь следы вырезанных листов."  
            narrator "Ты открываешь другой раздел, затем третий. Картина повторяется снова и снова. Всё, что касается создания Ордена, сохранилось почти полностью. Но все подробности о преодолении Прилива отсутствуют."
            narrator "Судя по состоянию бумаги, это было сделано много лет назад. Кто-то потратил немало времени, чтобы убрать эти сведения из разных архивных записей."
            narrator "На полях одного из отчётов сохранилась едва заметная пометка: «Доступ ограничён решением Совета». Это первое объяснение, которое тебе удаётся найти."
    
    with fade

    narrator "В какой-то момент ты ощущаешь на себе чей-то долгий и внимательный взгляд."
    narrator "Подняв глаза, ты видишь, будто на тебя из темноты дальних стеллажей пристально смотрит укутанный в черный плащ незнакомец."
    narrator "Заметив твой ответный взгляд, он поспешно скрывается из виду."
    narrator "Когда ты берешь в руки следующий том, в конце прохода снова кто-то появляется. На этот раз сомнений нет — кроме тебя и архивариуса в зале находится ещё один человек."

    menu:
        "Преследовать незнакомца":
            "Добежав до места, где незнакомец стоял минуту назад, ты не находишь никого."
            "Недавнее присутствие постороннего в зале выдают лишь следы сапог на пыльном полу."

    if hero.reason >=7:
        narrator "При взгляде на пол ты замечаешь крошечную гербовую печать."
        narrator "Ты берешь ее в руки и внимательно осматриваешь."
        narrator "Через пару секунд ты понимаешь, где видел знак на печати — это символ дома Триллианов, одного из старейших и влиятельнейших семейств Морвейна."
        narrator "Кажется, ты нащупал зацепку. Если кто и может поведать о прошлом, то это наследник старого дома доорденских времен."
        
        $ trillian_seal_found_flag = True
        $ inventory_items.append(InvItem(
            "unknown_seal", 
            "Неизвестная печать",
            "images/misc/trillian_seal.png",
            "Неизвестная печать, оброненная незнакомцем в архивах Ордена",
            1
        ))

    else:
        narrator "Осмотрев место, ты не находишь ничего примечательного и возвращаешься назад."
        narrator "Ты продолжаешь изучение очередного тома, ощущая наступающую с каждой минутой усталость."

        if hero.aspect >= 2:
            call dream_scene(
                [
                    "На короткое мгновение ты чувствуешь, как мир вокруг тебя темнеет.",
                    "Из непроглядной темноты всплывает незнакомая фигура с таинственным знаком на груди.",
                    "Тебе кажется, будто ты видел этот знак всего несколько минут назад...",
                ],
                "rykard",
                [],
                [],
                True)

            narrator "Ты приходишь в себя после видения."
            narrator ""

    menu:
        "Продолжить изучение":
            if (order_history_explored_flag == True):
                narrator "Ты понимаешь, что видел этот знак на грудни незнакомца совсем недавно — при изучении хроник Морвейна."
                narrator "Знак принадлежит дому Триллианов — одному из старейших и влиятельнийших домов города."
                narrator "У Триллианов есть своя гигантская библиотека, в которой наверняка могут храниться сведения о Морвейне доорденских времен."
                narrator "Кажется, настало время нанести визит их потомку и распросить его."
            else:
                narrator "Еще через час безрезультатных поисков ты понимаешь, что сегодня уже не узнаешь ничего нового."
                narrator "Разочарованно ты выходишь из архива."

    $ dream_char("cornelius default", [center])

    narrator "Ты возвращаешься к архиварусу."
    narrator "Старик тихо посапывает."

    menu:
        "Вернуть книги":
            edmund "Спасибо, бро!"

    if girl_picture_found_flag:
        menu:
            "Упомянуть про картинку":
                narrator "Старик смущенно улыбается."
                edmund "Ах, это... Когда-то и я был молод."
                edmund "Можешь оставить себе, если хочешь."

                menu:
                    "Вернуть картинку":
                        narrator "Тебе кажется, что на секунду в глазах Эдмунда ты видишь ностальгическую слезу."
                        edmund "Спасибо, юноша, что на время вернул старика в прошлое."
                        $ remove_item("girl_picture")
                        $ add_stat(hero, "mercy", 1)
                    "Оставить картинку":
                        narrator "Старик подмигивает тебе."
                        edmund "Она не раз согреет тебя холодными ночами."

    edmund "Надеюсь, ты нашел, что искал."

    $ hide_dream_char("cornelius default")

    narrator "Настало время продолжить расследование."

    menu:
        "Отправиться к усадьбе Триллианов" if trillian_seal_found_flag or order_history_explored_flag:
            jump act_1_rykard_gang_counter

        "Искать улики на улице" if not (trillian_seal_found_flag or order_history_explored_flag):
            jump act_1_investigation_streets

label act_1_archives_agatha_quest:
    $ hard_fade("morvein_streets")

    narrator "Ты идешь к тайному месту."
    narrator "Ты видишь Агату"

    $ dream_char("agatha default", [center])

    agatha "Она обращается к тебе."

    menu:
        "Заговорить с ней":
            menu:
                "Схватить ее":
                    if hero.control > 3:
                        "Ты хватаешь ее."
                        $ agatha_arrested_flag = True
                        jump act_1_archives_agatha_quest_end
                    else:
                        "Ты упускаешь ее."
                "Отпустить ее":
                    "Ты отпускаешь ее."
                    $ agatha_release_flag = True
                    jump act_1_archives_agatha_quest_end
        "Схватить ее":
            "Ты упускаешь ее."
            $ agatha_runaway_flag = True
            jump act_1_archives_agatha_quest_end
    
    narrator "Агата кидает тебе в лицо непонятный порошок и убегает."
    
    hide agatha_default with dissolve

    call dream_scene(
        ["На короткое мгновение у тебя темнеет в глазах"],
        None,
        [],
        [],
        True)

    narrator "Ты гонишься за ней."

    if hero.aspect >= 3:
        narrator "Ты видишь скрытый путь."
        narrator "Ты настигаешь ее."

        menu:
            "Схватить ее и доставить в собор":
                $ agatha_arrested_flag = True
            "Отпустить ее":
                $ agatha_release_flag = True
    else:
        $ agatha_runaway_flag = True

    jump act_1_archives_agatha_quest_end

label act_1_archives_agatha_quest_end:
    scene temple_council
    with fade

    show edmund default at center
    with dissolve

    if agatha_arrested_flag:
        edmund "Мы довольны, го в архив"
        jump act_1_archives_explore
    else:
        edmund "Мы разочарованы"
        narrator "Придется начать собственное расследование"
        jump act_1_investigation_streets

label act_1_rykard_gang_counter:
    $ hard_fade("morvein_streets")

    narrator "Герою навстречу выходит банда из трех человек."

    if hero.prof == PROF.MONK:
        narrator "Бандиты видят, что герой монах."
        narrator "Героя сразу пропускают дальше."
        jump act_1_rykard_before_mansion

    if hero.prof == PROF.DOCTOR:
        if agatha_release_flag:
            narrator "Бандиты останавливают героя."
            narrator "Агата вступается за героя."
            narrator "Бандиты отпускают героя."
            jump act_1_rykard_before_mansion

        if agatha_runaway_flag:
            narrator "Бандиты останавливают героя."
            narrator "Главарь предлагает герою отдать все деньги."

            menu:
                "Отдать все деньги":
                    narrator "Герой отдает бандитам все деньги."
                    $ remove_all_gold()
                    narrator "Бандиты дают герою пройти дальше."
                    jump act_1_rykard_before_mansion

                "Отказаться отдать деньги":
                    narrator "Герой отказывается отдать деньги."
                    jump act_1_rykard_gang_counter_guard_save

        if agatha_arrested_flag:
            narrator "Бандиты узнают героя."
            jump act_1_rykard_gang_counter_guard_save

    jump act_1_rykard_before_mansion

label act_1_rykard_gang_counter_guard_save:
    narrator "Бандиты нападают на героя."
    narrator "Героя спасает вооруженный страж Рикарда."
    $ hero_saved_by_guard = True
    jump act_1_rykard_before_mansion

label act_1_rykard_before_mansion:
    $ hard_fade("trillian_house")

    $ dream_char("rykard guard armed", [center])

    if hero_saved_by_guard:
        narrator "Герой вместе со стражем Рикарда заходит в особняк."
    else:
        narrator "Страж Рикарда встречает героя у входа."

        if trillian_seal_found_flag:
            rykard_armed_guard "Вас ждут."
        else:
            narrator "Герой говорит, что у него есть пара вопросов к хозяину."
            rykard_armed_guard "Вас уже ждут."

    jump act_1_rykard_house

label act_1_rykard_house:
    $ hard_fade("trillian_drawing_room")

    $ dream_char("rykard default", [center])

    narrator "Героя встречает Рикард в особняке."
    rykard "Меня зовут Рикард фон Триллиан."
    rykard "Мой род был одним из старейших родов Морвейна еще до возвышения Ордена."
    rykard "Триллианы помнят город таким, каким он был до нынешних запретов, страхов и молчания."
    rykard "Я давно искал встречи с вами."
    rykard "У вас наверняка накопилась куча вопросов."
    rykard "Пройдемте в библиотеку. Там я смогу на них ответить."

    jump act_1_rykard_library

label act_1_rykard_library:
    $ hard_fade("trillian_library")

    $ dream_char("rykard default", [center])

    rykard "Под Морвейном спит древнее существо."
    rykard "Несколько сотен лет назад монахи не уничтожили его."
    rykard "Они просто усыпили его и с тех пор держат в этом состоянии."
    rykard "Я слышал странные слухи."
    rykard "Будто певцы Ордена в последнее время сменяются слишком часто."

    if has_inventory_item("choir_resonance_notes"):
        menu:
            "Показать Рикарду вырванные страницы о хоре":
                narrator "Герой показывает Рикарду вырванные страницы о хоре."
                rykard "Значит, черные слухи об Ордене подтвердились."
                rykard "Они действительно используют певцов, чтобы поддерживать сон существа."
            "Не показывать страницы":
                narrator "Герой не показывает Рикарду вырванные страницы о хоре."

    rykard "Раньше Морвейном управляли древние роды."
    rykard "Они знали о существе под городом."
    rykard "И у них получалось как-то договариваться с ним."
    rykard "Так продолжалось, пока не случился кризис."

    if order_history_explored_flag:
        narrator "Герой вспоминает страницу хроники о Триллианах и их участии в жертвоприношениях."
        rykard "Да."
        rykard "В прошлом моего рода есть вещи, которыми невозможно гордиться."
        narrator "Рикард мрачнеет."
        rykard "Но это давно в прошлом."
        rykard "И я предлагаю вам убедиться в этом самому."
        jump act_1_rykard_altar
    else:
        rykard "Если вы сомневаетесь, я предлагаю пойти вместе в храм."
        rykard "Там вы сможете убедиться, что я говорю правду."
        rykard "Пойдемте в гостиную, обсудим там."

    jump act_1_path_choice 

label act_1_rykard_altar:
    $ hard_fade("trillian_altar_grotto")

    $ dream_char("rykard default", [center])

    narrator "Герой видит алтарь."
    narrator "Алтарь выглядит заброшенным."
    rykard "Он не использовался уже несколько сотен лет."
    rykard "Все это давно осталось в прошлом."

    if hero.aspect >= 2:
        call dream_scene(
            [
                "Герой видит короткое видение.",
                "Рикард стоит перед алтарем с кинжалом в руке.",
                "Рикард пронзает кого-то кинжалом."
            ],
            "rykard horror",
            [],
            [],
            True)

        $ hard_fade("trillian_altar_grotto")

    narrator "Герой и Рикард возвращаются в гостиную."

    jump act_1_path_choice

label act_1_path_choice:
    $ hard_fade("trillian_drawing_room")

    narrator "Ты стоишь в гостиной."
    narrator "Пора сделать выбор."

    menu:
        "Отправиться в храм с Рикардом":
            jump act_1_rykard_ancient_temple
        "Сдать Рикарда Ордену":
            jump act_1_rykard_arrest

    jump act_1_path_choice


label act_1_rykard_arrest:
    $ hard_fade("trillian_drawing_room")

    narrator "Герой говорит Рикарду, что ему нужно немного подумать."
    narrator "Герой покидает особняк Триллианов."

    $ hard_fade("temple_council")

    $ dream_char("edmund default", [center])

    narrator "Герой возвращается в Совет и требует срочной аудиенции."
    narrator "Герой сообщает, что Рикард знает о существе под Морвейном."
    narrator "Герой сообщает, что Рикард собирался вести его к этому существу."
    narrator "Герой говорит, что намерения Рикарда неясны."
    narrator "Совет решает, что в текущем кризисе не может рисковать."
    narrator "Совет отправляет стражу за Рикардом."

    $ dream_char("rykard default", [center])

    narrator "Вскоре Рикарда приводят в зал Совета."
    narrator "Совет требует от Рикарда объяснений."
    narrator "Рикард говорит, что Орден боится не его, а правды."
    narrator "Совет приказывает задержать Рикарда до выяснения обстоятельств."

    jump act_1_rykard_interrogation

label act_1_rykard_interrogation:
    $ hard_fade("temple_interrogation_room")

    narrator "Рикарда уводят на допрос."
    narrator "Герой слышит начало допроса из-за двери."
    narrator "Совет требует от Рикарда рассказать путь к существу под Морвейном."
    narrator "Рикард отвечает, что Орден и так знает путь."
    narrator "За дверью раздается удар."
    narrator "Рикард говорит, что герой все равно узнает правду."
    narrator "Герой понимает, что теперь пойдет в храм вместе с Орденом."
    narrator "Герой понимает, что сомнения никуда не исчезли."

    jump act_1_order_ancient_temple

label act_1_rykard_ancient_temple:
    $ hard_fade("morvein_ancient_temple")

    $ dream_char("rykard default", [center])

    narrator "Ты идешь в храм с Рикардом."

    return

label act_1_order_ancient_temple:
    $ hard_fade("morvein_ancient_temple")

    $ dream_char("edmund default", [center])

    narrator "Ты идешь в храм с Орденом."

    return
